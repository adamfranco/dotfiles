[user]
    name = Adam Franco
    email = afranco@middlebury.edu

[alias]
    co = checkout
    lol = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    addnw = !sh -c 'git diff -U0 -w --no-color "$@" | git apply --cached --ignore-whitespace --unidiff-zero -'
    su = submodule update --init --recursive

[apply]
    whitespace = fix

[pager]
    color = true

[status]
    color = auto

[push]
    default = simple

[pull]
	rebase = false

[core]
    excludesfile = ~/.gitignore
    filemode = false

[gui]
    fontdiff = -family Courier -size 10 -weight normal -slant roman -underline 0 -overstrike 0
    stageuntracked = no
[guitool "stash/pop"]
    cmd = git stash pop
    noconsole = yes
[guitool "svn/rebase"]
    cmd = git svn rebase
[guitool "svn/dcommit"]
    cmd = git svn dcommit
[guitool "svn/fetch"]
    cmd = git svn fetch
[guitool "stash/ stash"]
    cmd = git stash
    noconsole = yes
[guitool "stash/clear"]
    cmd = git stash clear
    noconsole = yes
